            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-dab", "-f", "8C", "-sn" , "4059" ],
            "console": "externalTerminal"
