    "version": "0.2.0",
    "configurations": [
        {
            "name": "Examples",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildExamples",
            "program": "${workspaceFolder}/Examples/bin/Debug/net10.0/Examples.dll",
            "args": [],
            "console": "externalTerminal"
        },
        {
            "name": "RadI0",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": [],
            "console": "externalTerminal"
        },
        {
            "name": "RadI0 - FM",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-f", "104MHz" ],
            "console": "externalTerminal"
        },
                {
            "name": "RadI0 - DAB",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-dab" ],
            "console": "externalTerminal"
        },
        {
            "name": "RadI0 help",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-help"],
            "console": "externalTerminal"
        },
        {
            "name": "DAB from file, wave output",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-if", "/temp/DAB.raw", "-wave", "/temp/audio.wave"],
            "console": "externalTerminal"
        },
        {
            "name": "FM from file, wave output",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-fm", "-if", "/temp/FM.raw", "-wave", "/temp/audio.wave"],
            "console": "externalTerminal"
        },
        {
            "name": "DAB from /temp/7C.raw",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-dab", "-ifile", "/temp/7C.raw"],
            "console": "externalTerminal"
        },
        {
            "name": "FM from /temp/FM.raw",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
            "program": "${workspaceFolder}/RadI0/bin/Debug/net10.0/RadI0.dll",
            "args": ["-fm", "-ifile", "/temp/FM.raw"],
            "console": "externalTerminal"
        },
        {
            "name": "FM 103.2 MHz",
            //"type": "dotnet",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildRadI0",
